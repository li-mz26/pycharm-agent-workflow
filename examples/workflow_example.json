{
  "id": "example_workflow_001",
  "name": "示例数据处理工作流",
  "description": "读取数据、清洗、分析的工作流（branch 稳定版本）",
  "nodes": [
    {
      "id": "start_001",
      "type": "start",
      "name": "开始",
      "position": {"x": 100, "y": 100},
      "config": {
        "outputs": {"raw_data": "list"}
      }
    },
    {
      "id": "code_001",
      "type": "code",
      "name": "数据清洗",
      "position": {"x": 300, "y": 100},
      "config": {
        "codeFile": "nodes/code_001.py",
        "inputs": {"raw_data": "start_001.raw_data"},
        "outputs": {"cleaned_data": "list", "has_data": "boolean"}
      }
    },
    {
      "id": "branch_001",
      "type": "branch",
      "name": "数据量检查",
      "position": {"x": 500, "y": 100},
      "config": {
        "branchField": "has_data",
        "branchCases": {
          "true": "agent_001",
          "false": "code_002"
        },
        "defaultTarget": "code_002"
      }
    },
    {
      "id": "agent_001",
      "type": "agent",
      "name": "数据分析",
      "position": {"x": 700, "y": 50},
      "config": {
        "promptFile": "nodes/agent_001_prompt.md",
        "model": "gpt-4",
        "inputs": {"cleaned_data": "code_001.cleaned_data"},
        "outputs": {"summary": "string"}
      }
    },
    {
      "id": "code_002",
      "type": "code",
      "name": "空数据处理",
      "position": {"x": 700, "y": 150},
      "config": {
        "codeFile": "nodes/code_002.py",
        "outputs": {"message": "string"}
      }
    },
    {
      "id": "end_001",
      "type": "end",
      "name": "结束",
      "position": {"x": 900, "y": 100},
      "config": {}
    }
  ],
  "edges": [
    {"id": "edge_001", "source": "start_001", "target": "code_001"},
    {"id": "edge_002", "source": "code_001", "target": "branch_001"},
    {"id": "edge_003", "source": "branch_001", "target": "agent_001", "condition": "true"},
    {"id": "edge_004", "source": "branch_001", "target": "code_002", "condition": "false"},
    {"id": "edge_005", "source": "agent_001", "target": "end_001"},
    {"id": "edge_006", "source": "code_002", "target": "end_001"}
  ],
  "variables": {
    "raw_data": {"type": "list"},
    "cleaned_data": {"type": "list"},
    "has_data": {"type": "boolean"},
    "summary": {"type": "string"},
    "message": {"type": "string"}
  }
}
